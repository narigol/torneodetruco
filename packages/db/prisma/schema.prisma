generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ORGANIZER
  PLAYER
}

enum Plan {
  FREE
  PRO
}

enum TournamentFormat {
  GROUPS_AND_KNOCKOUT
  SINGLE_ELIMINATION
}

enum TournamentStatus {
  DRAFT
  REGISTRATION
  IN_PROGRESS
  FINISHED
}

enum MatchStatus {
  PENDING
  IN_PROGRESS
  FINISHED
}

enum Phase {
  GROUP
  ROUND_OF_16
  QUARTERFINAL
  SEMIFINAL
  FINAL
}

enum NotificationType {
  TOURNAMENT_CREATED
  REGISTRATION_OPEN
  TOURNAMENT_STARTED
  TOURNAMENT_FINISHED
  LOCATION_INVITE
  TOURNAMENT_INVITATION
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  name                   String
  password               String
  role                   Role      @default(PLAYER)
  plan                   Plan      @default(FREE)
  planExpiresAt          DateTime?
  dni                    String?   @unique
  phone                  String?
  locality               String?
  province               String?
  country                String?
  instagram              String?   // Solo para ORGANIZER
  acceptsLocationInvites Boolean   @default(false)
  acceptsEmailNotifications Boolean @default(true)
  pendingActivation      Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  player      Player?
  tournaments Tournament[] @relation("TournamentAdmin")

  followers     Follow[]              @relation("Following")
  following     Follow[]              @relation("Follower")
  notifications Notification[]
  interests     TournamentInterest[]
  reglamentos   Reglamento[]

  invitationsSent       Invitation[] @relation("InvitationsSent")
  invitationsReceived   Invitation[] @relation("InvitationsReceived")
  tournamentRegistrations TournamentRegistration[]
  matchAudits           MatchAudit[]
  passwordResetTokens   PasswordResetToken[]
}

model Player {
  id        String   @id @default(cuid())
  name      String
  email     String?
  dni       String?  @unique
  phone     String?
  locality  String?
  provincia String?
  confirmed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  teamPlayers TeamPlayer[]
}

model Tournament {
  id              String           @id @default(cuid())
  name            String
  description     String?
  format          TournamentFormat
  status          TournamentStatus @default(DRAFT)
  published       Boolean          @default(false)
  startDate       DateTime?
  endDate         DateTime?
  startTime       String?
  location        String?
  locality        String?
  province        String?
  qualifyPerGroup Int              @default(2)
  playersPerTeam  Int              @default(2)
  maxPlayers      Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  adminId String
  admin   User   @relation("TournamentAdmin", fields: [adminId], references: [id])

  reglamentoId String?
  reglamento   Reglamento? @relation(fields: [reglamentoId], references: [id])

  teams         Team[]
  groups        Group[]
  matches       Match[]
  notifications Notification[]
  interests     TournamentInterest[]
  invitations   Invitation[]
  registrations TournamentRegistration[]
}

model Reglamento {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  contenido   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  adminId String
  admin   User   @relation(fields: [adminId], references: [id])

  torneos Tournament[]
}

model Invitation {
  id           String           @id @default(cuid())
  status       InvitationStatus @default(PENDING)
  createdAt    DateTime         @default(now())

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  inviterId String
  inviter   User   @relation("InvitationsSent", fields: [inviterId], references: [id])

  userId String
  user   User   @relation("InvitationsReceived", fields: [userId], references: [id])

  notifications Notification[]

  @@unique([tournamentId, userId])
}

model TournamentRegistration {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
}

model TournamentInterest {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now())

  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([userId, tournamentId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Notification {
  id           String           @id @default(cuid())
  type         NotificationType
  read         Boolean          @default(false)
  message      String?
  createdAt    DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tournamentId String?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  invitationId String?
  invitation   Invitation? @relation(fields: [invitationId], references: [id], onDelete: SetNull)
}

model Team {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  teamPlayers    TeamPlayer[]
  groupStandings GroupStanding[]
  homeMatches    Match[]         @relation("MatchHome")
  awayMatches    Match[]         @relation("MatchAway")
  wonMatches     Match[]         @relation("MatchWinner")
}

model TeamPlayer {
  id       String @id @default(cuid())
  teamId   String
  playerId String

  team   Team   @relation(fields: [teamId],   references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([teamId, playerId])
}

model Group {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  standings GroupStanding[]
  matches   Match[]
}

model GroupStanding {
  id      String @id @default(cuid())
  points  Int    @default(0)
  wins    Int    @default(0)
  losses  Int    @default(0)
  draws   Int    @default(0)
  scored  Int    @default(0)
  against Int    @default(0)

  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  teamId  String
  team    Team   @relation(fields: [teamId], references: [id])

  @@unique([groupId, teamId])
}

model Match {
  id        String      @id @default(cuid())
  phase     Phase
  status    MatchStatus @default(PENDING)
  homeScore Int?
  awayScore Int?
  scheduledAt DateTime?
  location    String?
  round     Int?
  games     Json?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id])

  homeTeamId String
  homeTeam   Team   @relation("MatchHome", fields: [homeTeamId], references: [id])

  awayTeamId String?
  awayTeam   Team?  @relation("MatchAway", fields: [awayTeamId], references: [id])

  winnerId String?
  winner   Team?   @relation("MatchWinner", fields: [winnerId], references: [id])

  audits MatchAudit[]
}

model MatchAudit {
  id           String   @id @default(cuid())
  action       String
  previousData Json?
  newData      Json?
  createdAt    DateTime @default(now())

  matchId String
  match   Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RankingConfig {
  key                    String   @id @default("global")
  tournamentPlayedPoints Int      @default(10)
  matchPlayedPoints      Int      @default(3)
  groupWinPoints         Int      @default(5)
  roundOf16WinPoints     Int      @default(8)
  quarterfinalWinPoints  Int      @default(12)
  semifinalWinPoints     Int      @default(18)
  finalWinPoints         Int      @default(30)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
